{
  "id": "./",
  "name": "DWG Sketch PWA Editor 2D",
  "short_name": "DWG Sketch",
  "description": "Mở DWG trực tiếp bằng LibreDWG WebAssembly nội bộ; sửa hình học và tự bố trí chữ tránh đường/hình; hỗ trợ TRIM đường cong, SCALE, AREA, màu, tiếng Việt, PNG/PDF và Clipboard.",
  "lang": "vi",
  "dir": "ltr",
  "start_url": "./index.html?v=0.16.2",
  "scope": "./",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#202124",
  "theme_color": "#202124",
  "categories": [
    "productivity",
    "utilities",
    "graphics"
  ],
  "icons": [
    {
      "src": "./icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/dxf": [
          ".dxf"
        ],
        "application/json": [
          ".json",
          ".dwgsketch.json"
        ],
        "text/plain": [
          ".dxf"
        ],
        "application/acad": [
          ".dwg"
        ],
        "application/x-dwg": [
          ".dwg"
        ]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}
